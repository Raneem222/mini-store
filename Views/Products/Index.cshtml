@model List<mini_store.Models.Product>

@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">إدارة المنتجات</h2>
        <a asp-action="Create" class="btn btn-success">+ إضافة منتج</a>
    </div>

    <form asp-action="Index" method="get" class="d-flex gap-2 mb-4">
    <input type="text" name="searchTerm" value="@ViewBag.CurrentSearch"
           class="form-control" placeholder="ابحث باسم المنتج...">
    <button type="submit" class="btn btn-primary">بحث</button>
    @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
    {
        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
    }
</form>

    <table class="table table-bordered table-hover text-center align-middle bg-white">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>الاسم</th>
                <th>السعر</th>
                <th>الوصف</th>
                <th>الصورة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Id</td>
                    <td>@product.Name</td>
                    <td>@product.Price ريال</td>
                    <td>@product.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@product.Id"
                           class="btn btn-sm btn-outline-warning">تعديل</a>
                        <a asp-action="Delete" asp-route-id="@product.Id"
                           class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('متأكدة من حذف هذا المنتج؟')">حذف</a>
                    </td>
                    <td>
    @if (!string.IsNullOrEmpty(product.Image))
    {
        <img src="~/images/@product.Image" style="width:50px; height:50px; object-fit:cover; border-radius:8px;" />
    }
</td>
                </tr>
            }
        </tbody>
    </table>
</div>