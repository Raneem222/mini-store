@{

    ViewData["Title"] = "التفاصيل";
    var product = ViewBag.Product;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm p-3">

                <img src="~/images/@product.Image" class="card-img-top mb-3"
                     style="max-height: 300px; object-fit: contain;" alt="@product.Name">

                <div class="card-body text-center">
                    <h3 class="mb-3">@product.Name</h3>
                    <h5 class="text-success mb-3">@product.Price ريال</h5>
                    <p class="text-muted">@product.Description</p>

                    <div class="mt-4 d-flex justify-content-center gap-3">
                        <a asp-action="Products" asp-route-id="@product.CategoryId"
                           class="btn btn-outline-secondary">← العودة للمنتجات</a>
                        <a asp-action="Index" class="btn btn-success">الصفحة الرئيسية</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>