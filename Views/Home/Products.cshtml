@{
    ViewData["Title"] = "المنتجات";
    var products = ViewBag.FilteredProducts;
    string categoryName = ViewBag.CategoryName;
}

<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">منتجات: @categoryName</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← رجوع للتصنيفات</a>
    </div>

    <div class="row g-4">
        @foreach (var prod in products)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm text-center">
                    <img src="~/images/@prod.Image" class="card-img-top p-4"
                         style="height: 220px; object-fit: contain;" alt="@prod.Name">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@prod.Name</h5>
                        <h6 class="text-success mb-3">@prod.Price ريال</h6>
                        <a asp-action="Details" asp-route-name="@prod.Name"
                           class="btn btn-primary rounded-pill px-4">عرض التفاصيل</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>